# Application
APP_NAME=Online Judge
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars

# Database
DATABASE_URL=postgresql+asyncpg://judge:judge_pass@localhost:5432/online_judge

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Judge
MAX_CODE_LENGTH=65536
MAX_OUTPUT_LENGTH=1048576
CONCURRENT_JUDGE_JOBS=2

# Browser access
CORS_ORIGINS_RAW=http://localhost:8000,http://127.0.0.1:8000,http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
